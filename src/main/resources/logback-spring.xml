<?xml version="1.0" encoding="UTF-8"?>
<!--
  STDIO MCP servers must keep stdout exclusively for JSON-RPC. This config logs
  ONLY to a file (no console appender), so nothing pollutes the protocol stream.
-->
<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/mcp-server.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="FILE"/>
    </root>
</configuration>
